{
  "buildCommand": null,
  "outputDirectory": ".",
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/$1" }
  ],
  "functions": {
    "api/notion-insights.js": {
      "includeFiles": "api/notion-data.json",
      "maxDuration": 60
    },
    "api/generate-tip-suggestions.js": {
      "maxDuration": 30
    }
  },
  "headers": [
    {
      "source": "/notion-data.json",
      "headers": [
        { "key": "Cache-Control", "value": "no-store, must-revalidate" }
      ]
    },
    {
      "source": "/api/notion-insights",
      "headers": [
        { "key": "Cache-Control", "value": "no-store, must-revalidate" }
      ]
    }
  ]
}
